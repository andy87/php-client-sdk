{
  "name": "andy87/php-client-sdk",
  "description": "Base abstractions for typed PHP API clients.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Andy87\\PhpClientSdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Andy87\\PhpClientSdk\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src tests --level=5",
    "cs-fix": "php-cs-fixer fix --diff",
    "cs-check": "php-cs-fixer fix --diff --dry-run"
  }
}
